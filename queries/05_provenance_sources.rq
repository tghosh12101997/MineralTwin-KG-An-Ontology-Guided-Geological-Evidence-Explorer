PREFIX mt: <https://w3id.org/mineraltwin/ontology/>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?depositName ?source
WHERE {
  ?deposit a mt:MineralDeposit ;
           rdfs:label ?depositName ;
           prov:wasDerivedFrom ?evidence .
  ?evidence a mt:EvidenceSource ;
            rdfs:label ?source .
}
ORDER BY ?depositName
LIMIT 150
